@model BlogProject.Models.CreatePostViewModel

@{
    ViewData["Title"] = "Добавить статью";
}

<div class="container">
    <h1>Добавить статью</h1>

    <form asp-action="Create" method="post">
        <div class="form-group">
            <label for="Title">Заголовок</label>
            <input type="text" class="form-control" id="Title" name="Title" value="@Model.Title" required />
        </div>

        <div class="form-group">
            <label for="Summary">Краткое содержание</label>
            <input type="text" class="form-control" id="Summary" name="Summary" value="@Model.Summary" required />
        </div>

        <div class="form-group">
            <label for="Content">Содержание</label>
            <textarea class="form-control" id="Content" name="Content" required>@Model.Content</textarea>
        </div>

        <div class="form-group">
            <label>Теги</label><br>
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="checkbox" id="tag1" name="Tags" value="Разработка">
                <label class="form-check-label" for="tag1">Разработка</label>
            </div>
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="checkbox" id="tag2" name="Tags" value=".NET CORE">
                <label class="form-check-label" for="tag2">.NET CORE</label>
            </div>
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="checkbox" id="tag3" name="Tags" value="Java">
                <label class="form-check-label" for="tag3">Java</label>
            </div>
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="checkbox" id="tag4" name="Tags" value="Mac OS">
                <label class="form-check-label" for="tag4">Mac OS</label>
            </div>
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="checkbox" id="tag5" name="Tags" value="Docker">
                <label class="form-check-label" for="tag5">Docker</label>
            </div>
        </div>

        <div class="form-group text-center mt-4">
            <button type="submit" class="btn btn-success btn-block">Добавить статью</button>
            <a href="@Url.Action("Index", "Posts")" class="btn btn-secondary btn-block">Отмена</a>
        </div>
    </form>
</div>
