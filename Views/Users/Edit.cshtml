@model EditUserViewModel

<h1>Edit User</h1>

<form asp-action="Edit" method="post">
    <div>
        <label for="Username">Username</label>
        <input type="text" id="Username" name="Username" asp-for="Username" required />
    </div>
    <div>
        <label for="Email">Email</label>
        <input type="email" id="Email" name="Email" asp-for="Email" required />
    </div>
    <div>
        <label for="Password">Password</label>
        <input type="password" id="Password" name="Password" asp-for="Password" placeholder="Leave empty to keep current password" />
    </div>
    <div>
        <label><input type="checkbox" name="IsUser" asp-for="IsUser" /> User</label>
        <label><input type="checkbox" name="IsAdmin" asp-for="IsAdmin" /> Admin</label>
        <label><input type="checkbox" name="IsModerator" asp-for="IsModerator" /> Moderator</label>
    </div>
    <button type="submit">Save Changes</button>
</form>
